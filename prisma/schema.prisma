generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Etablissement {
  id              String            @id @default(uuid())
  nom             String
  plan_actuel     String            @default("Standard")
  actif           Boolean           @default(false)
  expiration      DateTime?         // null = illimité
  
  utilisateurs    Utilisateur[]
  categories      Categorie[]
  produits        Produit[]
  stocks          Stock[]
  mouvements      MouvementStock[]
  
  clients         Client[]
  fournisseurs    Fournisseur[]
  commandes       Commande[]
  depenses        Depense[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Utilisateur {
  id              String            @id @default(uuid())
  nom             String
  email           String            @unique
  mot_de_passe    String
  role            String            @default("VENDEUR") // SUPER_ADMIN, PATRON, VENDEUR
  est_verifie     Boolean           @default(false)
  token_verification String?
  
  // Le SUPER_ADMIN n'a pas d'établissement
  etablissement_id String?
  etablissement    Etablissement?   @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  // Relation optionnelle pour lier un vendeur à un stock
  stock_id        String?
  stock           Stock?            @relation(fields: [stock_id], references: [id])
  
  mouvements_enregistres MouvementStock[]
  commandes_vendeur      Commande[]      @relation("VendeurCommande")
  depenses_enregistrees  Depense[]       @relation("UtilisateurDepense")
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Categorie {
  id              String            @id @default(uuid())
  nom             String
  description     String?
  
  etablissement_id String
  etablissement    Etablissement    @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  produits        Produit[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Produit {
  id                String          @id @default(uuid())
  nom               String
  code_barre        String?
  
  etablissement_id  String
  etablissement     Etablissement   @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  categorie_id      String
  categorie         Categorie       @relation(fields: [categorie_id], references: [id])
  
  prix_achat_detail Int
  prix_achat_gros   Int
  prix_vente_detail Int
  prix_vente_gros   Int
  
  mouvements        MouvementStock[]
  lignes_commande   LigneCommande[]
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  @@unique([etablissement_id, code_barre]) // Un code barre est unique au sein d'un établissement
}

model Stock {
  id                String          @id @default(uuid())
  nom               String
  adresse           String?
  telephone         String?
  est_externe       Boolean         @default(false)
  
  etablissement_id  String
  etablissement     Etablissement   @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  stock_parent_id   String?
  stock_parent      Stock?          @relation("StockHierarchy", fields: [stock_parent_id], references: [id])
  stocks_enfants    Stock[]         @relation("StockHierarchy")
  
  vendeurs          Utilisateur[]
  
  mouvements_sortants MouvementStock[] @relation("SourceStock")
  mouvements_entrants MouvementStock[] @relation("DestinationStock")
  
  commandes_recues  Commande[]       @relation("StockCommandeDestination")
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model MouvementStock {
  id                    String          @id @default(uuid())
  type                  String          // Gardé pour rétrocompatibilité
  
  etablissement_id      String
  etablissement         Etablissement   @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  produit_id            String
  produit               Produit         @relation(fields: [produit_id], references: [id])
  
  stock_source_id       String?
  stock_source          Stock?          @relation("SourceStock", fields: [stock_source_id], references: [id])
  
  stock_destination_id  String?
  stock_destination     Stock?          @relation("DestinationStock", fields: [stock_destination_id], references: [id])
  
  quantite              Int
  prix_unitaire_applique Int
  
  utilisateur_id        String
  utilisateur           Utilisateur     @relation(fields: [utilisateur_id], references: [id])
  
  date_mouvement        DateTime        @default(now())
}

model Client {
  id              String      @id @default(uuid())
  nom             String
  telephone       String?
  adresse         String?
  
  etablissement_id String
  etablissement   Etablissement @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  commandes       Commande[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Fournisseur {
  id              String      @id @default(uuid())
  nom             String
  telephone       String?
  adresse         String?
  
  etablissement_id String
  etablissement   Etablissement @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Commande {
  id              String      @id @default(uuid())
  numero_facture  String      @unique
  type_vente      String      // GROS, DETAIL, TRANSFERT_INTERNE
  statut_paiement String      // PAYE, PARTIEL, NON_PAYE
  montant_total   Int
  montant_paye    Int         @default(0)
  
  etablissement_id String
  etablissement   Etablissement @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  client_id       String?
  client          Client?     @relation(fields: [client_id], references: [id])
  
  // Le stock qui a servi à vendre
  stock_source_id String?
  
  // Si transfert interne, vers quel stock
  stock_destination_id String?
  stock_destination    Stock? @relation("StockCommandeDestination", fields: [stock_destination_id], references: [id])

  vendeur_id      String
  vendeur         Utilisateur @relation("VendeurCommande", fields: [vendeur_id], references: [id])
  
  lignes          LigneCommande[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model LigneCommande {
  id              String      @id @default(uuid())
  
  commande_id     String
  commande        Commande    @relation(fields: [commande_id], references: [id], onDelete: Cascade)
  
  produit_id      String
  produit         Produit     @relation(fields: [produit_id], references: [id])
  
  quantite        Int
  prix_unitaire   Int         // Prix vendu
  prix_achat_unitaire Int     // Prix d'achat à l'instant T pour calculer le bénéfice
}

model Depense {
  id              String      @id @default(uuid())
  motif           String      // Salaire, Transport, Facture...
  description     String?
  montant         Int
  date_depense    DateTime    @default(now())
  
  etablissement_id String
  etablissement   Etablissement @relation(fields: [etablissement_id], references: [id], onDelete: Cascade)
  
  enregistre_par_id String
  enregistre_par  Utilisateur @relation("UtilisateurDepense", fields: [enregistre_par_id], references: [id])
}
